# Acceso Norte — variables locales
#
# El .env solo lo usa Docker Compose para parametrizar la base local.
# En producción WordPress lee credenciales desde wp-config.php (gestionado
# por el 1-click installer de SiteGround), no de este archivo.

# DB local (usada por docker-compose.yml)
WP_DB_NAME=accesonorte
WP_DB_USER=accesonorte
WP_DB_PASSWORD=accesonorte
WP_DB_ROOT_PASSWORD=rootpass
